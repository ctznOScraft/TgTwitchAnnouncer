# Telegram Bot Token
# Получить: https://t.me/BotFather
TG_TOKEN=your_telegram_bot_token_here

# Twitch API Credentials
# Получить: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_SECRET=your_twitch_client_secret_here

# Twitch EventSub Webhook Settings
# URL, по которому Twitch будет отправлять уведомления
CALLBACK_URL=https://your-domain.com/webhook

# Secret для верификации webhook подписей Twitch (любая случайная строка)
WEBHOOK_SECRET=your_random_webhook_secret_here

# Порт для локального HTTP сервера
PORT=4192
